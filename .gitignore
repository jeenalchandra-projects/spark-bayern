# =============================================================================
# .gitignore — Files Git should NEVER upload to GitHub
# =============================================================================
# WHY THIS EXISTS:
# Some files must never be shared publicly:
# - .env contains your real API keys and passphrase (secrets)
# - __pycache__ and .pyc files are compiled Python — not needed in the repo
# - node_modules contains thousands of dependency files — regenerated by npm install
# - Uploaded documents must NEVER go into Git (personal data, GDPR)
# =============================================================================

# --- SECRET FILES (most important) ---
.env
.env.local
.env.production
*.env

# --- PYTHON ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.log

# --- NODE / JAVASCRIPT ---
node_modules/
.next/
out/
dist/
.npm
*.tsbuildinfo

# --- UPLOADS / DOCUMENTS (GDPR — never commit real documents) ---
uploads/
*.pdf
*.docx
*.doc
*.tmp
synthetic-data/*.pdf

# --- OPERATING SYSTEM ---
.DS_Store
Thumbs.db
*.swp
*.swo

# --- IDE ---
.vscode/settings.json
.idea/
*.iml

# --- DOCKER ---
docker-compose.override.yml
