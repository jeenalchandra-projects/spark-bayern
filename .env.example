# =============================================================================
# SPARK-BAYERN — ENVIRONMENT VARIABLES
# =============================================================================
# HOW TO USE THIS FILE:
# 1. Copy this file and rename the copy to ".env"  (command: cp .env.example .env)
# 2. Fill in your actual values where it says YOUR_... below
# 3. NEVER commit your .env file to GitHub — it contains secrets
# 4. The .env.example file (this file) is safe to commit — it has no real secrets
# =============================================================================


# -----------------------------------------------------------------------------
# LLM (AI MODEL) SETTINGS
# -----------------------------------------------------------------------------
# Your API key from app.requesty.ai
# How to get it: Log in to app.requesty.ai → API Keys → Create Key
LLM_API_KEY=YOUR_REQUESTY_API_KEY_HERE

# The URL that all AI requests are sent to
# Do not change this unless Requesty changes their endpoint
LLM_BASE_URL=https://router.requesty.ai/v1

# Which AI model to use
# Cheapest good option: mistral/mistral-large-latest
# Better but more expensive: anthropic/claude-sonnet-4-5
# Alternative: openai/gpt-4o
LLM_MODEL=mistral/mistral-large-latest

# Your application name sent to Requesty for analytics (can be anything)
LLM_APP_TITLE=SPARK-Bayern


# -----------------------------------------------------------------------------
# SECURITY — ACCESS CONTROL
# -----------------------------------------------------------------------------
# This passphrase protects the app from public access.
# Anyone who opens the app must enter this code before they can use it.
# WHY THIS EXISTS: GDPR Article 25 requires access control when processing
# personal data, even in a demo. Without this, anyone on the internet could
# upload real citizen documents.
# Set this to any phrase you choose — something easy to share with your demo audience.
# Example: "hackathon2026" or "bmds-demo"
DEMO_ACCESS_CODE=YOUR_CHOSEN_PASSPHRASE_HERE


# -----------------------------------------------------------------------------
# SERVICE PORTS (which port each service listens on)
# -----------------------------------------------------------------------------
# You rarely need to change these unless another app on your computer
# is already using these port numbers.
API_GATEWAY_PORT=8000
QUALITY_SERVICE_PORT=8001
RAG_SERVICE_PORT=8002
TRANSLATION_SERVICE_PORT=8003


# -----------------------------------------------------------------------------
# SPARK CORE INTEGRATION (optional)
# -----------------------------------------------------------------------------
# If you have the full SPARK system running locally, fill in its URL here.
# If left as "disabled", our services will work in standalone mode.
# For the hackathon demo, standalone mode is fine.
SPARK_BASE_URL=disabled
# Example if SPARK is running: SPARK_BASE_URL=http://localhost:8004


# -----------------------------------------------------------------------------
# RAG SERVICE — BAYERN BUILDING CODE
# -----------------------------------------------------------------------------
# How many law paragraphs to retrieve when checking an application.
# Higher = more thorough but slower and uses more AI tokens.
# 5 is a good balance for a demo.
RAG_TOP_K=5

# Path where the Bayern Bauordnung (BayBO) PDF is stored inside the container
# You do not need to change this.
BAYBO_PDF_PATH=/app/data/baybo.pdf


# -----------------------------------------------------------------------------
# GDPR / PRIVACY SETTINGS
# -----------------------------------------------------------------------------
# Maximum file size accepted for upload (in megabytes)
# Keeps the system from being overwhelmed with huge files
MAX_UPLOAD_SIZE_MB=20

# How long (in seconds) to keep a processed result in memory before deleting it
# After this time, all data from that upload is gone from memory
# 300 = 5 minutes — enough for the user to read the results
RESULT_TTL_SECONDS=300


# -----------------------------------------------------------------------------
# RAILWAY DEPLOYMENT (filled in automatically by Railway, do not change)
# -----------------------------------------------------------------------------
# Railway sets PORT automatically — our app reads this to know which port to use
PORT=8000
